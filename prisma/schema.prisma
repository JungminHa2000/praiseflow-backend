datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model User {
  id                String       @id @default(uuid())
  name              String
  email             String       @unique
  passwordHash      String
  instrumentDefault String?
  voiceType         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  folders           Folder[]
  shareLinks        ShareLink[]
  annotations       Annotation[]
}

model Folder {
  id         String      @id @default(uuid())
  name       String
  parentId   String?
  parent     Folder?     @relation("FolderChildren", fields: [parentId], references: [id])
  children   Folder[]    @relation("FolderChildren")
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pieces     Piece[]
  shareLinks ShareLink[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
}

model Piece {
  id                String             @id @default(uuid())
  title             String
  fileUrl           String
  fileType          String
  fileHash          String?
  processingStatus  String             @default("pending")
  processingError   String?
  folderId          String
  folder            Folder             @relation(fields: [folderId], references: [id], onDelete: Cascade)
  analysis          Analysis?
  improvSuggestions ImprovSuggestion[]
  annotations       Annotation[]
  shareLinks        ShareLink[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([folderId])
}

model Analysis {
  id                  String   @id @default(uuid())
  pieceId             String   @unique
  piece               Piece    @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  keySignature        String?
  timeSignature       String?
  chartType           String?
  songTitle           String?
  melodyRecognised    Boolean  @default(false)
  chordProgression    Json?
  structureSections   Json?
  leadNotes           Json?
  tempo               String?
  confidenceLevel     String   @default("high")
  warnings            Json?
  rawClaudeResponse   String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ImprovSuggestion {
  id          String   @id @default(uuid())
  pieceId     String
  piece       Piece    @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  instrument  String?
  voiceType   String?
  style       String?
  suggestions Json
  pdfUrl      String?
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pieceId])
}

model Annotation {
  id         String   @id @default(uuid())
  pieceId    String
  piece      Piece    @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strokeData Json     @default("[]")
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([pieceId, userId])
  @@index([pieceId])
}

model ShareLink {
  id        String    @id @default(uuid())
  pieceId   String?
  piece     Piece?    @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  folderId  String?
  folder    Folder?   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique @default(uuid())
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([pieceId])
  @@index([folderId])
}
